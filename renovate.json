{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex",
    "dockerfile",
    "github-actions"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)Dockerfile$/"
      ],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "FROM\\s+[^\\s]+alpine(?<alpineMajor>\\d+)\\.(?<alpineMinor>\\d+)[^\\n]*",
        "(?m)^ARG OPENSSH_VERSION=(?<currentValue>[^\\s]+)$"
      ],
      "depNameTemplate": "alpine_{{alpineMajor}}_{{alpineMinor}}/openssh",
      "datasourceTemplate": "repology",
      "versioningTemplate": "loose"
    }
  ]
}
